generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  pending
  paid
  processing
  shipped
  delivered
  canceled
  refunded
  failed
}

enum ProductRegionType {
  lips
  nails
  cheeks
  eyes
  face
  hair
}

enum ProductShadeFinish {
  matte
  glossy
  satin
  velvet
  shimmer
  cream
}

enum TryOnStatus {
  pending
  processing
  completed
  failed
}

enum PriceSnapshotSource {
  manual
  crawler
  api
}

enum PriceInsightLevel {
  unknown
  low
  competitive
  high
}

model User {
  id       Int     @id @default(autoincrement())
  fullName String?
  mobile   String  @unique
  email    String?
  password String
  role     String  @default("customer")
  isActive Boolean @default(true)

  cart      Cart?
  orders    Order[]
  addresses Address[]

  beautyProfile BeautyProfile?
  tryOnSessions VirtualTryOnSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Brand {
  id       Int     @id @default(autoincrement())
  name     String
  slug     String  @unique
  logo     String?
  isActive Boolean @default(true)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          Int     @id @default(autoincrement())
  name        String
  slug        String  @unique
  description String?
  image       String?
  isActive    Boolean @default(true)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          Int     @id @default(autoincrement())
  name        String
  englishName String?
  slug        String  @unique
  description String?
  shortDesc   String?
  isActive    Boolean @default(true)

  brandId    Int?
  categoryId Int?

  brand    Brand?    @relation(fields: [brandId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])

  variants ProductVariant[]
  images   ProductImage[]

  cartItems  CartItem[]
  orderItems OrderItem[]

  shades       ProductShade[]
  intelligence ProductIntelligence?
  experience   ProductExperience?

  competitorLinks CompetitorProductLink[]
  priceInsight    ProductPriceInsight?

  tryOnSessions VirtualTryOnSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductVariant {
  id        Int      @id @default(autoincrement())
  title     String
  sku       String   @unique
  volume    Int?
  barcode   String?
  price     Decimal  @db.Decimal(18, 2)
  salePrice Decimal? @db.Decimal(18, 2)
  stock     Int      @default(0)
  isActive  Boolean  @default(true)

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  cartItems  CartItem[]
  orderItems OrderItem[]

  shade ProductShade?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  imageUrl  String
  alt       String?
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Cart {
  id     Int @id @default(autoincrement())
  userId Int @unique

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id        Int  @id @default(autoincrement())
  cartId    Int
  productId Int?
  variantId Int
  quantity  Int  @default(1)

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product?       @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, variantId])
}

model Address {
  id             Int     @id @default(autoincrement())
  userId         Int
  title          String?
  receiverName   String
  receiverMobile String
  province       String
  city           String
  addressLine    String
  postalCode     String?
  plaque         String?
  unit           String?
  isDefault      Boolean @default(false)
  isActive       Boolean @default(true)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id     Int @id @default(autoincrement())
  userId Int

  user User @relation(fields: [userId], references: [id])

  addressId Int?
  address   Address? @relation(fields: [addressId], references: [id])

  status OrderStatus @default(pending)
  total  Decimal     @default(0) @db.Decimal(18, 2)

  authority String?

  shippingReceiverName   String?
  shippingReceiverMobile String?
  shippingProvince       String?
  shippingCity           String?
  shippingAddressLine    String?
  shippingPostalCode     String?
  shippingPlaque         String?
  shippingUnit           String?

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id Int @id @default(autoincrement())

  orderId   Int
  productId Int?
  variantId Int

  productName  String  @default("")
  variantTitle String?
  sku          String?
  price        Decimal @db.Decimal(18, 2)
  quantity     Int
  total        Decimal @default(0) @db.Decimal(18, 2)

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?       @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  createdAt DateTime @default(now())
}

model ProductShade {
  id Int @id @default(autoincrement())

  productId Int
  variantId Int? @unique

  name         String
  code         String?
  hexColor     String?
  region       ProductRegionType
  finish       ProductShadeFinish?
  opacity      Float?
  previewImage String?
  sortOrder    Int                 @default(0)
  isActive     Boolean             @default(true)

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  tryOnSessions VirtualTryOnSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductIntelligence {
  id        Int @id @default(autoincrement())
  productId Int @unique

  aiGeneratedTitle       String?
  aiGeneratedShortDesc   String?
  aiGeneratedDescription String?

  seoTitle       String?
  seoDescription String?
  seoKeywords    String[]

  storyTitle String?
  storyText  String?

  howToUse String?
  warnings String?

  suitableFor String[]
  ingredients String[]
  benefits    String[]

  complementaryProductIds Int[]

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductExperience {
  id        Int @id @default(autoincrement())
  productId Int @unique

  visualTheme  String?
  mood         String?
  colorPalette String[]

  motionPreset   String?
  heroVideoUrl   String?
  threeDModelUrl String?
  arModelUrl     String?

  scentFamily String?
  topNotes    String[]
  middleNotes String[]
  baseNotes   String[]

  season   String[]
  occasion String[]
  gender   String?

  longevity String?
  sillage   String?

  skinTypes   String[]
  routineStep String?
  texture     String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BeautyProfile {
  id     Int @id @default(autoincrement())
  userId Int @unique

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  skinType  String?
  undertone String?

  scentFamilies   String[]
  favoriteNotes   String[]
  allergies       String[]
  preferredBrands String[]

  budgetMin Decimal? @db.Decimal(18, 2)
  budgetMax Decimal? @db.Decimal(18, 2)

  beautyGoals String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VirtualTryOnSession {
  id     Int @id @default(autoincrement())
  userId Int

  productId Int
  shadeId   Int?

  region ProductRegionType?

  sourceImageUrl String?
  resultImageUrl String?

  status       TryOnStatus @default(pending)
  errorMessage String?

  consentAccepted Boolean @default(false)

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  shade   ProductShade? @relation(fields: [shadeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Competitor {
  id         Int     @id @default(autoincrement())
  name       String
  slug       String  @unique
  websiteUrl String?

  priceSelector        String?
  salePriceSelector    String?
  titleSelector        String?
  availabilitySelector String?
  priceMultiplier      Float   @default(1)

  isActive Boolean @default(true)

  productLinks CompetitorProductLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompetitorProductLink {
  id Int @id @default(autoincrement())

  productId    Int
  competitorId Int

  url         String
  title       String?
  externalSku String?
  isActive    Boolean @default(true)

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  competitor Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  snapshots PriceSnapshot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PriceSnapshot {
  id Int @id @default(autoincrement())

  competitorProductLinkId Int
  competitorProductLink   CompetitorProductLink @relation(fields: [competitorProductLinkId], references: [id], onDelete: Cascade)

  price     Decimal  @db.Decimal(18, 2)
  salePrice Decimal? @db.Decimal(18, 2)
  currency  String   @default("IRR")

  isAvailable Boolean             @default(true)
  source      PriceSnapshotSource @default(manual)

  capturedAt DateTime @default(now())
}

model ProductPriceInsight {
  id        Int @id @default(autoincrement())
  productId Int @unique

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  feloralPrice   Decimal  @db.Decimal(18, 2)
  minMarketPrice Decimal? @db.Decimal(18, 2)
  avgMarketPrice Decimal? @db.Decimal(18, 2)
  maxMarketPrice Decimal? @db.Decimal(18, 2)
  suggestedPrice Decimal? @db.Decimal(18, 2)

  insightLevel PriceInsightLevel @default(unknown)

  summary           String?
  recommendedAction String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
